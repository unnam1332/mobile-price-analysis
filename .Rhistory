print(sum(is.na(mobile_data)))
# Histogram
hist(mobile_data$battery_power,
main="Battery Power Distribution",
xlab="Battery Power")
# Boxplot
boxplot(mobile_data$ram,
main="RAM Distribution",
ylab="RAM")
# Scatter plot
plot(mobile_data$ram,
mobile_data$price_range,
main="RAM vs Price Range",
xlab="RAM",
ylab="Price Range",
pch=19)
# Correlation
ram_price_correlation <- cor(mobile_data$ram, mobile_data$price_range)
print("Correlation:")
print(ram_price_correlation)
# Regression model
price_model <- lm(price_range ~ ram + battery_power, data=mobile_data)
print(summary(price_model))
